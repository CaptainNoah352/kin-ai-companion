# Optional: enable real model responses.
# Leave unset to use the built-in local demo companion.

# Required for the GitHub/static Google login + encrypted Drive vault path.
# This is the public OAuth web client id from Google Cloud, not a secret.
VITE_GOOGLE_CLIENT_ID=
VITE_KIN_REMOTE_ORIGIN=
VITE_KIN_HOSTING=
# Public HTTPS origin for a hosted Kin API, such as https://kin-api.onrender.com.
# Do not include a trailing /api.
VITE_KIN_API_BASE_URL=
KIN_ALLOWED_HOSTS=.ts.net
# Comma-separated browser origins allowed to call server.mjs in hosted API mode.
KIN_ALLOWED_ORIGINS=

# Preferred: OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=http://127.0.0.1:988
OPENROUTER_APP_NAME=Kin Mental Wellness Companion

# Optional fallback: OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=

# Local API port used by server.mjs
PORT=8787
